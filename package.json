{
  "name": "crypto_wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx prisma generate --schema=./backend/prisma/schema.prisma && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "cd backend && npm run dev",
    "studio": "cd backend && npx prisma studio",
