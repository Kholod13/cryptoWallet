    "bcrypt": "^6.0.0",
    "ccxt": "^4.5.44",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.34.0",
    "i18next": "^25.8.19",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
